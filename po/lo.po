#: src/SettingsDialog.cpp:300
#, c-format
msgid "<b>Only the first %u hotkeys(s) are enabled.</b>\n"
msgstr "<b>ເປີດໃຊ້ງານສະເພາະປຸ່ມລັດ %u ອັນທຳອິດເທົ່ານັ້ນ.</b>\n"

#: src/SettingsDialog.cpp:305
#, c-format
msgid ""
"The &lt;SUPER&gt;+%u combination seems already in use by another process.\n"
"Check your Xfce settings."
msgstr ""
"ປຸ່ມປະສົມ &lt;SUPER&gt;+%u ເບິ່ງຄືວ່າຖືກໃຊ້ໂດຍໂປຣແກຣມອື່ນແລ້ວ.\n"
"ກະລຸນາກວດສອບການຕັ້ງຄ່າ Xfce ຂອງທ່ານ."

#: src/docklike.desktop.in:5
msgid "Docklike Taskbar"
msgstr "ແຖບວຽກແບບດັອກ (Docklike Taskbar)"

#: src/docklike.desktop.in:6
msgid "A modern, minimalist taskbar for Xfce"
msgstr "ແຖບວຽກທີ່ທັນສະໄໝ ແລະ ລຽບງ່າຍສຳລັບ Xfce"

